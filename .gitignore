# Generated outputs (anywhere in the tree)
out/
**/output/

# Raw SEM image datasets — keep large originals out of git.
# The small no-infobar variant is the canonical input for sam3_single_image/
# and is allow-listed below so collaborators can run the scripts.
**/UW_SEM_Images_batch_1/
**/UW_SEM_Images_batch_1_segments/
!UW_SEM_Images_batch_1_no_infobar/

# Label Studio runtime artifacts (only meaningful when running the labeling stack)
**/sem-crack-labeling/data/
**/sem-crack-labeling/exports/
**/sem-crack-labeling/label_studio_data/

# Deprecated package data folders
**/data/raw/
**/data/processed/
**/data/annotations/

# PyInstaller
**/packaging/build/
**/packaging/dist/
*.spec.bak
